#!/usr/bin/env bash
set -euo pipefail

source_dir="$(realpath "${1:?Jenkins workspace is required}")"
case "$source_dir" in
  /var/lib/jenkins/workspace/*) ;;
  *) echo "source must be a Jenkins workspace" >&2; exit 2 ;;
esac

set -a
source /etc/webfetch/service.env
set +a

app_root="${WEBFETCH_APP_ROOT:?WEBFETCH_APP_ROOT is required}"
service_user="webfetch"
release_id="${BUILD_TAG:-jenkins-$(date -u +%Y%m%d%H%M%S)}"
release_id="${release_id//[^a-zA-Z0-9_.-]/-}"
release_dir="$app_root/releases/$release_id"
previous="$(readlink -f "$app_root/current" 2>/dev/null || true)"
services=(webfetch-browser-worker webfetch-http-worker webfetch-api)

cleanup_old_releases() {
  local releases_dir="$app_root/releases"
  local keep="${WEBFETCH_RELEASES_TO_KEEP:-5}"
  local current_release candidate
  local index=0
  local -a release_dirs=()

  if [[ ! "$keep" =~ ^[0-9]+$ ]] || (( keep < 2 )); then
    echo "WEBFETCH_RELEASES_TO_KEEP must be an integer greater than or equal to 2" >&2
    return 1
  fi

  current_release="$(readlink -f "$app_root/current")"
  mapfile -t release_dirs < <(
    find "$releases_dir" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' \
      | sort -nr \
      | cut -d' ' -f2-
  )

  for candidate in "${release_dirs[@]}"; do
    candidate="$(realpath "$candidate")"
    if [[ "$(dirname "$candidate")" != "$(realpath "$releases_dir")" ]]; then
      echo "refusing to remove release outside $releases_dir: $candidate" >&2
      return 1
    fi
    if (( index < keep )) || [[ "$candidate" == "$current_release" ]]; then
      ((index += 1))
      continue
    fi
    rm -rf -- "$candidate"
    echo "removed_old_release=$candidate"
    ((index += 1))
  done
}

for service in "${services[@]}"; do
  systemctl stop "$service" 2>/dev/null || true
done

install -d -o "$service_user" -g "$service_user" "$release_dir"
rsync -a --delete \
  --exclude .git --exclude .jenkins-venv --exclude data --exclude __pycache__ \
  "$source_dir/" "$release_dir/"
chown -R "$service_user:$service_user" "$release_dir"

sudo -u "$service_user" python3 -m venv "$release_dir/.venv"
sudo -u "$service_user" "$release_dir/.venv/bin/python" -m pip install "$release_dir[browser]"
sudo -u "$service_user" "$release_dir/.venv/bin/playwright" install chromium
"$release_dir/.venv/bin/alembic" -c "$release_dir/alembic.ini" upgrade head
ln -sfn "$release_dir" "$app_root/current"
systemctl restart webfetch-api webfetch-http-worker webfetch-browser-worker

port="${WEBFETCH_SERVER__PORT:-33333}"
ready=false
for _ in $(seq 1 30); do
  if curl --fail --silent "http://127.0.0.1:$port/health/ready" >/dev/null; then
    ready=true
    break
  fi
  sleep 1
done
if [[ "$ready" != true ]]; then
  if [[ -n "$previous" && -d "$previous" ]]; then
    ln -sfn "$previous" "$app_root/current"
    systemctl restart webfetch-api webfetch-http-worker webfetch-browser-worker
  fi
  echo "deployment health check failed; rollback attempted" >&2
  exit 1
fi

cleanup_old_releases
echo "deployed_release=$release_dir"
