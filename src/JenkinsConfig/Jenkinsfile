pipeline {
    agent any

    parameters {
        string(name: 'HEALTH_URL', defaultValue: 'http://127.0.0.1:33333', description: 'WebFetch health-check base URL')
    }

    triggers {
        pollSCM('H/30 * * * *')
    }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Test') {
            steps {
                sh '''
                    python3 -m venv .jenkins-venv
                    .jenkins-venv/bin/python -m pip install -e '.[dev]'
                    .jenkins-venv/bin/ruff check src tests
                    mkdir -p build/test-results
                    .jenkins-venv/bin/pytest --cov=webfetch_service --cov-fail-under=80 \
                      --junitxml=build/test-results/pytest.xml
                '''
            }
        }
        stage('Stop, update and start') {
            steps {
                sh '''
                    sudo /usr/local/sbin/webfetch-jenkins-deploy "$WORKSPACE"
                '''
            }
        }
        stage('Smoke test') {
            steps {
                sh '''
                    health_url="${HEALTH_URL:-http://127.0.0.1:33333}"
                    curl --fail --silent --show-error "$health_url/health/live"
                    curl --fail --silent --show-error "$health_url/health/ready"
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'build/test-results/*.xml', allowEmptyArchive: true
        }
    }
}
